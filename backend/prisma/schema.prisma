generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  passwordHash    String
  createdAt       DateTime       @default(now())
  bio             String?
  username        String?        @unique
  clubsCreated    Club[]
  clubMemberships ClubMember[]
  clubPrompts     ClubPrompt[]
  dares           Dare[]         @relation("DareAuthor")
  targetedDares   Dare[]         @relation("DareTarget")
  dareProofs      DareProof[]
  likes               Like[]
  truthComments       TruthComment[]
  truthReports        TruthReport[]
  truthCommentReports TruthCommentReport[]
  truths              Truth[]              @relation("TruthAuthor")
  targetedTruths      Truth[]              @relation("TruthTarget")
}

model Truth {
  id           String         @id @default(uuid())
  authorId     String
  content      String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  targetUserId String
  author       User           @relation("TruthAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetUser   User           @relation("TruthTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  comments     TruthComment[]
  reports      TruthReport[]

  @@index([authorId])
  @@index([targetUserId])
}

model TruthComment {
  id        String   @id @default(uuid())
  text      String
  truthId   String
  userId    String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  truth   Truth          @relation(fields: [truthId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  TruthComment?        @relation("TruthCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies TruthComment[]       @relation("TruthCommentReplies")
  reports TruthCommentReport[]

  @@index([truthId])
  @@index([userId])
  @@index([parentId])
}

model TruthReport {
  id        String   @id @default(uuid())
  truthId   String
  userId    String
  reason    String
  details   String?
  createdAt DateTime @default(now())

  truth Truth @relation(fields: [truthId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([truthId, userId])
  @@index([truthId])
  @@index([userId])
}

model TruthCommentReport {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  reason    String
  details   String?
  createdAt DateTime @default(now())

  comment TruthComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model Dare {
  id           String      @id @default(uuid())
  authorId     String
  content      String
  maxAttempts  Int         @default(1)
  expiresAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  targetUserId String
  attemptsUsed Int         @default(0)
  completedAt  DateTime?
  author       User        @relation("DareAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetUser   User        @relation("DareTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  proofs       DareProof[]

  @@index([authorId])
  @@index([targetUserId])
}

model DareProof {
  id              String         @id @default(uuid())
  dareId          String
  userId          String
  mediaType       ProofMediaType
  fileUrl         String
  durationSeconds Int?
  text            String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  dare            Dare           @relation(fields: [dareId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dareId])
  @@index([userId])
}

model Club {
  id          String       @id @default(uuid())
  name        String
  description String?
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  members     ClubMember[]
  prompts     ClubPrompt[]
}

model ClubMember {
  id        String   @id @default(uuid())
  clubId    String
  userId    String
  createdAt DateTime @default(now())
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
}

model ClubPrompt {
  id          String         @id @default(uuid())
  clubId      String
  authorId    String
  type        ClubPromptType
  content     String
  maxAttempts Int?
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  club        Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model Like {
  id         String         @id @default(uuid())
  userId     String
  targetId   String
  targetType LikeTargetType
  createdAt  DateTime       @default(now())
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId, targetType])
  @@index([targetId, targetType])
}

enum ClubPromptType {
  truth
  dare
}

enum LikeTargetType {
  truth
  dare
  club
  truth_comment
}

enum ProofMediaType {
  video
  audio
  file
}
