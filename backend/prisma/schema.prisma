generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  passwordHash    String
  createdAt       DateTime       @default(now())
  deletedAt       DateTime?
  bio             String?
  username        String?        @unique
  isPrivate       Boolean        @default(false)
  clubsCreated    Club[]
  clubInvitesReceived ClubInvite[] @relation("ClubInviteInvitee")
  clubInvitesSent     ClubInvite[] @relation("ClubInviteInviter")
  clubJoinRequests    ClubJoinRequest[]
  clubMemberships ClubMember[]
  clubReports     ClubReport[] @relation("ClubReportReporter")
  clubPromptComments ClubPromptComment[]
  clubPrompts     ClubPrompt[]
  clubPromptResponses ClubPromptResponse[]
  dares           Dare[]         @relation("DareAuthor")
  targetedDares   Dare[]         @relation("DareTarget")
  dareProofs      DareProof[]
  likes               Like[]
  truthComments       TruthComment[]
  truthReports        TruthReport[]
  truthCommentReports TruthCommentReport[]
  truths              Truth[]              @relation("TruthAuthor")
  targetedTruths      Truth[]              @relation("TruthTarget")
  passwordResetTokens PasswordResetToken[]
  notifications       Notification[]       @relation("NotificationRecipient")
  notificationsActed  Notification[]       @relation("NotificationActor")
  supportTickets      SupportTicket[]
}

model SupportTicket {
  id            String                @id @default(uuid())
  userId        String
  category      SupportTicketCategory
  description   String
  referenceId   String?
  referenceType String?
  status        SupportTicketStatus   @default(open)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@index([referenceType, referenceId])
}

model PasswordResetToken {
  id           String   @id @default(uuid())
  userId       String
  tokenHash    String
  expiresAt    DateTime
  usedAt       DateTime?
  attemptCount Int      @default(0)
  ipAddress    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, usedAt])
}

model Truth {
  id           String         @id @default(uuid())
  authorId     String
  content      String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  targetUserId String
  author       User           @relation("TruthAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetUser   User           @relation("TruthTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  comments     TruthComment[]
  reports      TruthReport[]

  @@index([authorId])
  @@index([targetUserId])
}

model TruthComment {
  id        String   @id @default(uuid())
  text      String
  truthId   String
  userId    String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  truth   Truth          @relation(fields: [truthId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  TruthComment?        @relation("TruthCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies TruthComment[]       @relation("TruthCommentReplies")
  reports TruthCommentReport[]

  @@index([truthId])
  @@index([userId])
  @@index([parentId])
}

model TruthReport {
  id        String   @id @default(uuid())
  truthId   String
  userId    String
  reason    String
  details   String?
  createdAt DateTime @default(now())

  truth Truth @relation(fields: [truthId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([truthId, userId])
  @@index([truthId])
  @@index([userId])
}

model TruthCommentReport {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  reason    String
  details   String?
  createdAt DateTime @default(now())

  comment TruthComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model Dare {
  id           String      @id @default(uuid())
  authorId     String
  content      String
  maxAttempts  Int         @default(1)
  expiresAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  targetUserId String
  attemptsUsed Int         @default(0)
  completedAt  DateTime?
  author       User        @relation("DareAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetUser   User        @relation("DareTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  proofs       DareProof[]

  @@index([authorId])
  @@index([targetUserId])
}

model DareProof {
  id              String         @id @default(uuid())
  dareId          String
  userId          String
  mediaType       ProofMediaType
  fileUrl         String
  durationSeconds Int?
  text            String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  dare            Dare           @relation(fields: [dareId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubPromptResponses ClubPromptResponse[]

  @@index([dareId])
  @@index([userId])
}

model Club {
  id             String         @id @default(uuid())
  name           String
  slug           String         @unique
  description    String?
  iconName       String         @default("groups")
  avatarUrl      String?
  coverUrl       String?
  visibility     ClubVisibility @default(public)
  status         ClubStatus     @default(active)
  rules          String?
  blockedWords   String[]       @default([])
  tags           String[]       @default([])
  memberCount    Int            @default(0)
  promptCount    Int            @default(0)
  lastActivityAt DateTime?
  archivedAt     DateTime?
  deletedAt      DateTime?
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  auditLogs      ClubAuditLog[]
  createdBy      User           @relation(fields: [createdById], references: [id], onDelete: Cascade)
  invites        ClubInvite[]
  joinRequests   ClubJoinRequest[]
  members        ClubMember[]
  prompts        ClubPrompt[]
  reports        ClubReport[]
  promptComments ClubPromptComment[]
  promptResponses ClubPromptResponse[]
  notifications   Notification[]

  @@index([visibility, status])
  @@index([visibility, status, lastActivityAt])
  @@index([name])
  @@index([lastActivityAt])
  @@index([memberCount])
  @@index([createdById])
}

model Notification {
  id            String           @id @default(uuid())
  userId        String
  actorId       String?
  type          NotificationType
  title         String
  body          String
  deepLink      String
  clubId        String?
  referenceType String?
  referenceId   String?
  dedupeKey     String?          @unique
  readAt        DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor         User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  club          Club?            @relation(fields: [clubId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([clubId])
  @@index([referenceType, referenceId])
}

model ClubMember {
  id          String           @id @default(uuid())
  clubId      String
  userId      String
  role        ClubMemberRole   @default(member)
  status      ClubMemberStatus @default(active)
  invitedById String?
  joinedAt    DateTime?
  lastSeenAt  DateTime?
  mutedUntil  DateTime?
  postingSuspendedUntil DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  club        Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId])
  @@index([userId, status])
  @@index([clubId, status])
  @@index([clubId, role])
  @@index([clubId, role, status])
  @@index([role])
}

model ClubInvite {
  id          String           @id @default(uuid())
  clubId      String
  inviteeId   String
  inviterId   String
  status      ClubMemberStatus @default(invited)
  code        String?
  message     String?
  expiresAt   DateTime?
  acceptedAt  DateTime?
  declinedAt  DateTime?
  cancelledAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  club        Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invitee     User             @relation("ClubInviteInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  inviter     User             @relation("ClubInviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([clubId, inviteeId, status])
  @@unique([code])
  @@index([inviteeId, status])
  @@index([clubId, status])
  @@index([inviterId])
}

model ClubJoinRequest {
  id           String           @id @default(uuid())
  clubId       String
  userId       String
  status       ClubMemberStatus @default(requested)
  message      String?
  reviewedById String?
  reviewedAt   DateTime?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  club         Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId, status])
  @@index([userId, status])
  @@index([clubId, status])
  @@index([reviewedById])
}

model ClubPrompt {
  id            String           @id @default(uuid())
  clubId        String
  authorId      String
  type          ClubPromptType
  status        ClubPromptStatus @default(published)
  content       String
  difficulty    String?
  attachments   Json?
  maxAttempts   Int?
  expiresAt     DateTime?
  publishedAt   DateTime?
  archivedAt    DateTime?
  removedAt     DateTime?
  removedById   String?
  removalReason String?
  answersCount  Int              @default(0)
  commentsCount Int              @default(0)
  likesCount    Int              @default(0)
  isPinned      Boolean          @default(false)
  isMembersOnly Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  author        User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  club          Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  comments      ClubPromptComment[]
  responses     ClubPromptResponse[]

  @@index([clubId, status])
  @@index([authorId])
  @@index([expiresAt])
  @@index([publishedAt])
  @@index([isPinned])
}

model ClubPromptResponse {
  id            String          @id @default(uuid())
  clubId        String
  promptId      String
  userId        String
  text          String?
  mediaUrl      String?
  mediaType     ProofMediaType?
  dareProofId   String?
  attemptsUsed  Int             @default(0)
  completedAt   DateTime?
  archivedAt    DateTime?
  removedAt     DateTime?
  removedById   String?
  removalReason String?
  likesCount    Int             @default(0)
  commentsCount Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  club          Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  comments      ClubPromptComment[]
  prompt        ClubPrompt      @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dareProof     DareProof?      @relation(fields: [dareProofId], references: [id], onDelete: SetNull)

  @@index([clubId])
  @@index([promptId])
  @@index([userId])
  @@index([createdAt])
  @@index([removedAt])
}

model ClubPromptComment {
  id            String               @id @default(uuid())
  clubId        String
  promptId      String
  responseId    String?
  userId        String
  parentId      String?
  text          String
  likesCount    Int                  @default(0)
  repliesCount  Int                  @default(0)
  editedAt      DateTime?
  removedAt     DateTime?
  removedById   String?
  removalReason String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  club          Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  prompt        ClubPrompt           @relation(fields: [promptId], references: [id], onDelete: Cascade)
  response      ClubPromptResponse?  @relation(fields: [responseId], references: [id], onDelete: Cascade)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        ClubPromptComment?   @relation("ClubPromptCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       ClubPromptComment[]  @relation("ClubPromptCommentReplies")

  @@index([clubId])
  @@index([promptId])
  @@index([responseId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
  @@index([removedAt])
}

model ClubReport {
  id         String               @id @default(uuid())
  clubId     String
  reporterId String
  targetType ClubReportTargetType
  targetId   String
  reason     String
  details    String?
  createdAt  DateTime             @default(now())
  club       Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  reporter   User                 @relation("ClubReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, targetType, targetId])
  @@index([clubId])
  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([clubId, targetType])
  @@index([createdAt])
}

model ClubAuditLog {
  id           String   @id @default(uuid())
  clubId       String
  actorId      String?
  targetUserId String?
  action       String
  entityType   String?
  entityId     String?
  metadata     Json?
  createdAt    DateTime @default(now())
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([actorId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

model Like {
  id         String         @id @default(uuid())
  userId     String
  targetId   String
  targetType LikeTargetType
  createdAt  DateTime       @default(now())
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId, targetType])
  @@index([targetId, targetType])
}

enum ClubPromptType {
  truth
  dare
}

enum ClubVisibility {
  public
  private
  invite_only
}

enum ClubStatus {
  active
  archived
  suspended
  deleted
}

enum ClubMemberRole {
  owner
  admin
  moderator
  member
}

enum ClubMemberStatus {
  active
  invited
  requested
  removed
  blocked
}

enum ClubPromptStatus {
  draft
  published
  archived
  removed
}

enum ClubReportTargetType {
  club
  club_prompt
  club_prompt_response
  club_prompt_comment
}

enum ClubJoinPolicy {
  open
  approval_required
  invite_only
}

enum LikeTargetType {
  truth
  dare
  club
  club_prompt
  club_response
  truth_comment
}

enum SupportTicketCategory {
  spam
  hate
  violence
  nudity
  other
}

enum SupportTicketStatus {
  open
  reviewing
  resolved
  dismissed
}

enum ProofMediaType {
  video
  audio
  file
}

enum NotificationType {
  club_created
  club_invite_received
  club_invite_accepted
  club_join_request_received
  club_join_request_approved
  club_join_request_rejected
  club_new_prompt
  club_prompt_response
  club_prompt_comment
  club_mention
  club_member_promoted
  feed_truth_received
  feed_dare_received
  feed_truth_comment
  feed_like
  feed_dare_proof_submitted
  account_password_reset_completed
}
