{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/src/server.js",
    "test": "jest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:populate": "tsx scripts/populate-feed.ts",
    "db:inspect-user": "tsx scripts/inspect-user-table.ts",
    "test:db:deploy": "tsx scripts/run-prisma-test-command.ts migrate deploy",
    "test:db:reset": "tsx scripts/run-prisma-test-command.ts migrate reset --force",
    "test:db:studio": "tsx scripts/run-prisma-test-command.ts studio",
    "test:prepare": "npm run test:db:reset",
    "test:full": "npm run test:prepare && npm test"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@supabase/supabase-js": "^2.105.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "artillery": "^2.0.30",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
