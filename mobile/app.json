{
  "expo": {
    "name": "TODAN",
    "slug": "todan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/logo-light.png",
    "scheme": "todan",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/logo-light-adaptive.png",
        "monochromeImage": "./assets/icons/logo-light-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.pedrolabre.todan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/logo-light.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/logo-light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "391115ad-3ff3-4a9f-81a1-a42bd05793ec"
      }
    }
  }
}
